# Copy this file to .env and fill values before running.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,llama-3.1-70b-versatile
PINECONE_API_KEY=your_pinecone_api_key

# Pinecone serverless configuration
PINECONE_INDEX_NAME=sellsmart-catalog
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embedding provider: huggingface
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Twilio (required if you later send proactive outbound messages)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
